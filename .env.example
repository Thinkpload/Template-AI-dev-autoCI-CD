# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — copy to .env and fill in real values
# NEVER commit .env to git (pre-commit hook will block it)
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local development: Docker PostgreSQL (run: docker-compose up -d)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/template_dev

# Production: Neon serverless PostgreSQL
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Authentication (Better Auth) ──────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# ── Authentication (Clerk) — only if you chose Clerk in setup wizard ──────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
# CLERK_SECRET_KEY=sk_test_

# ── AI Providers ──────────────────────────────────────────────────────────────
# Set one or both — the app uses whichever is configured (provider-agnostic)
OPENAI_API_KEY=sk-placeholder-replace-with-your-openai-key
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-with-your-anthropic-key

# ── Upstash Redis (rate limiting + caching) ───────────────────────────────────
# Get from: console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=placeholder-replace-with-your-upstash-token

# ── Sentry (error monitoring) — optional ──────────────────────────────────────
# Get from: sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://placeholder@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=placeholder-replace-with-your-sentry-auth-token
NEXT_PUBLIC_SENTRY_DSN=https://placeholder@o0.ingest.sentry.io/0

# ── Inngest (background jobs) — optional ─────────────────────────────────────
# Dev server runs automatically with npm run dev (no keys needed locally)
# Production keys from: app.inngest.com
INNGEST_EVENT_KEY=placeholder-replace-with-your-inngest-event-key
INNGEST_SIGNING_KEY=placeholder-replace-with-your-inngest-signing-key

# ── SonarCloud (CI/CD quality gate) ───────────────────────────────────────────
# DO NOT put SONAR_TOKEN here — add it as a GitHub Secret instead:
# GitHub repo → Settings → Secrets and variables → Actions → New secret
# Name: SONAR_TOKEN, Value: token from sonarcloud.io

# ── Email (optional) ──────────────────────────────────────────────────────────
# Resend (transactional email): resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com
