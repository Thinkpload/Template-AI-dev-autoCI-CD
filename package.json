    "@radix-ui/react-slot": "^1.1.0",
    "@testing-library/dom": "^10.4.1",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.0",
    "lucide-react": "^0.400.0",
    "next": "^15.1.0",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.22.0",
    "zustand": "^5.0.0"
